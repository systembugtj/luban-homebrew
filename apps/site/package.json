{
  "name": "@luban-homebrew/site",
  "version": "0.1.0",
  "description": "luban-homebrew docs site — GitHub Pages",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm generate:sitemap && cross-env VITE_BASE=/luban-homebrew/ vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@wsxjs/wsx-base-components": "^0.0.26",
    "@wsxjs/wsx-core": "^0.0.26",
    "@wsxjs/wsx-i18next": "^0.0.26",
    "@wsxjs/wsx-press": "^0.0.26",
    "@wsxjs/wsx-router": "^0.0.26",
    "i18next": "^23.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.12.0",
    "@wsxjs/wsx-vite-plugin": "^0.0.26",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "fs-extra": "^11.3.0",
    "glob": "^10.4.5",
    "globals": "^16.5.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.46.4",
    "unocss": "^66.5.12",
    "vite": "^7.3.1",
    "vitest": "^3.2.6"
  }
}
